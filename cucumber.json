{
  "default": {
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "format": ["progress", "json:reports/cucumber-report.json"],
    "paths": ["src/test/features/**/*.feature"],
    "publishQuiet": true,
    "dryRun": false,
    "retry": 1,
    "parallel": 1,
    "require": ["src/hooks/**/*.ts", "src/test/steps/**/*.ts"],
    "requireModule": ["ts-node/register"]
  }
}
